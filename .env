# MCP Server
MCP_SERVER_URL=
APP_NAME=Seraphim BlueTeam MCP
APP_ENV=development
DEFAULT_LIMIT=10000

# LLM Mode
# KoboiLLM / OpenAI-compatible gateway
LLM_ENABLED=true
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=openai/gpt-5.5
LLM_TIMEOUT_SECONDS=60



#for redis
AUDIT_ENABLED=true
REDIS_URL=redis://127.0.0.1:6379/0
AUDIT_STREAM_KEY=seraphim:mcp:audit
AUDIT_MAX_LEN=1000
